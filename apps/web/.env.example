# apps/web: authenticated app with auth and tRPC API routes.
# Copy this file to apps/web/.env.local and fill in the values. Do not commit local env files.

# URLs. Leave blank when everything runs on one local/dev domain.
NEXT_PUBLIC_WWW_URL=https://www.example.com
NEXT_PUBLIC_APP_URL=https://app.example.com

# Database + Auth. Server-only; never prefix DATABASE_URL or BETTER_AUTH_SECRET with NEXT_PUBLIC_.
DATABASE_URL=postgresql://user:password@localhost:5432/app
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000
